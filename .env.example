# BambooHR Configuration
BAMBOO_API_KEY=your_api_key_here
BAMBOO_COMPANY_DOMAIN=cerbexa

# Optional filters
BAMBOO_APPLICATION_STATUS=ALL
# BAMBOO_JOB_ID=123
# BAMBOO_NEW_SINCE=2024-01-01 00:00:00

# Output
BAMBOO_OUTPUT_FORMAT=json
BAMBOO_OUTPUT_FILE=candidates_export

# CV / Resume download (optional)
BAMBOO_RESUMES_DIR=resumes